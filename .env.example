# Google Sheet CSV export URL
#
# How to get this URL:
#   1. Open your Google Sheet
#   2. File → Share → Publish to web
#   3. Under "Link", select the correct sheet tab and choose "Comma-separated values (.csv)"
#   4. Click "Publish" and copy the URL — it looks like:
#      https://docs.google.com/spreadsheets/d/SHEET_ID/pub?output=csv&gid=0
#
# Required sheet columns (first row must be headers):
#   id, title, time_start, time_end
#
# Optional columns:
#   title_en, address, lat, lng, description, description_en, tags
#   (tags = comma-separated, e.g. "music, culture")
#
# Coordinate rules:
#   address only        → coordinates fetched from Nominatim
#   lat + lng only      → address fetched from Nominatim
#   address + lat/lng   → used as-is (coordinates take precedence on the map)

SHEET_URL=
